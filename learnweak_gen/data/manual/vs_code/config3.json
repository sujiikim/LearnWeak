{
    "id": "config-3",
    "snapshot": "vscode",
    "config": [
      {
        "type": "download",
        "parameters": {
          "files": [
            {
              "url": "https://github.com/GAIR-NLP/PC-Agent-E/archive/refs/heads/main.zip",
              "path": "/home/user/Downloads/PC-Agent-E.zip"
            }
          ]
        }
      },
      {
        "type": "execute",
        "parameters": {
          "command": [
            "/bin/bash",
            "-c",
            "cd /home/user/Downloads && unzip -q PC-Agent-E.zip && rm -rf PC-Agent-E.zip && mv PC-Agent-E-main PC-Agent-E"
          ]
        }
      },
      {
        "type": "launch",
        "parameters": {
          "command": [
            "code",
            "/home/user/Downloads/PC-Agent-E"
          ]
        }
      },
      {
        "type": "activate_window",
        "parameters": {
          "window_name": "Visual Studio Code"
        }
      }
    ],
    "trajectory": "trajectories/",
    "related_apps": [
      "vscode"
    ],
    "evaluator": {
      "func": "infeasible"
    },
    "proxy": false,
    "fixed_ip": false,
    "possibility_of_env_change": "low",
    "provide_info": [
      "### File structure of this repository:\n",
      "PC-Agent-E/assets/first_image.png",
      "PC-Agent-E/assets/overview.png",
